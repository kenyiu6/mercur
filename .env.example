## ========================================
##  香港炒賣 MVP — 環境變數範本
##  將此檔複製為 .env 後填值
## ========================================

# --- AI scraper (建議用 Perplexity，內建 web search) ---
# 取得 API key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# 備用（fallback）：可不填
OPENAI_API_KEY=

# --- Backend secrets ---
JWT_SECRET=請改成隨機長字串
COOKIE_SECRET=請改成隨機長字串

# --- CORS ---
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000,http://localhost:5173
VENDOR_CORS=http://localhost:5174
AUTH_CORS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# --- Storefront ---
# 在 admin > Settings > Publishable API Keys 建立後填入
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_KEY=pk_test_xxx
REVALIDATE_SECRET=請改成隨機長字串

# --- Stripe (生產環境) ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
